{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash ./.hooks/guard-paths.sh"
      },
      {
        "command": "bash ./.hooks/scan-secrets.sh"
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash ./.hooks/guard-paths.sh"
      },
      {
        "command": "bash ./.hooks/scan-secrets.sh"
      },
      {
        "command": "bash ./.hooks/format-file.sh"
      }
    ]
  }
}
