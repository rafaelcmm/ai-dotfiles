{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "bash \"$HOME/.cursor/.hooks/guard-paths.sh\""
      },
      {
        "command": "bash \"$HOME/.cursor/.hooks/scan-secrets.sh\""
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash \"$HOME/.cursor/.hooks/guard-paths.sh\""
      },
      {
        "command": "bash \"$HOME/.cursor/.hooks/scan-secrets.sh\""
      },
      {
        "command": "bash \"$HOME/.cursor/.hooks/format-file.sh\""
      }
    ]
  }
}
