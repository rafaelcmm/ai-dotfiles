{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash \"${HOME}/.cursor/scripts/inject-skills-context-session-start.sh\"",
        "timeout": 15
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "bash \"${HOME}/.cursor/scripts/discover-skills-for-user-prompt.sh\"",
        "timeout": 15
      }
    ]
  }
}
