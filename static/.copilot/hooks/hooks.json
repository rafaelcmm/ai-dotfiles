{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/guard-paths.sh",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scan-secrets.sh",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/format-file.sh",
        "timeoutSec": 15
      }
    ]
  }
}
